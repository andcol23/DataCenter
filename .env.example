# ── Google OAuth (scope: gmail.send + Sheets) ───────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Google Sheets ────────────────────────────────────────────────────────────
GOOGLE_SHEET_ID=
# Recommended for GitHub Actions: service account key JSON with Editor access
# to the Sheet. Keep OAuth secrets too if the daily digest sends Gmail.
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Email ────────────────────────────────────────────────────────────────────
DAILY_DIGEST_TO=

# ── Pipeline tunables (optional) ─────────────────────────────────────────────
DRY_RUN=false
BATCH_SIZE=10
MAX_AGE_DAYS=7
MAX_ITEMS_PER_RUN=60
MAX_SHORTLIST=5
MONDAY_LOOKBACK_HOURS=
SHORTLIST_POOL_LIMIT=
SHORTLIST_WINDOW_HOURS=
CURATION_MIN_RELEVANCE=
REQUIRE_VALID_TAXONOMY=false

# ── Debug ─────────────────────────────────────────────────────────────────────
# LOG_LEVEL=DEBUG
